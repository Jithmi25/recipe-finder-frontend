{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://recipefinder-1-syd5.onrender.com/api/:path*"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://recipefinder-1-syd5.onrender.com"
  }
}
